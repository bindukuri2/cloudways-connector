# --- Cloudways credentials (only these two are required) ---
# Get the API key from https://platform.cloudways.com/api
CLOUDWAYS_EMAIL=you@example.com
CLOUDWAYS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: fallback server id ---
# The plugin normally resolves the server via its picker/create flow and passes
# serverId inside each DeployRequest. Set CLOUDWAYS_SERVER_ID here only if you
# want a hard fallback used when the plugin didn't provide one (useful for CI
# or single-server accounts). Leave commented out for normal use.
# CLOUDWAYS_SERVER_ID=1577767

# --- Server config ---
PORT=8787
HOST=127.0.0.1

# --- Optional ---
# Override the Cloudways API base URL if you're testing against a stub.
# CLOUDWAYS_API_BASE_URL=https://api.cloudways.com/api/v1
# Override the public app URL pattern Cloudways returns:
# CLOUDWAYS_APP_URL_PATTERN=https://{app_label}.cloudwaysapps.com
